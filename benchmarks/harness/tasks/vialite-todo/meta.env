# vialite-todo — quality/discipline benchmark.
#
# Unlike the p24/p34 tasks, this one does NOT check out a pinned commit of an
# external repo. The starting tree is the self-contained skeleton shipped in
# this task dir; the harness seeds each rep by copying it. The hidden suite
# and ground-truth defects live here too and are never copied into the rep's
# worktree (the runner and scorer keep them out).
SEED_DIR=skeleton
HIDDEN_DIR=hidden
DEFECTS=defects.json
TIMEOUT_S=5400
